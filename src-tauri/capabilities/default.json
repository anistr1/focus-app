{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "autostart:default",
    "notification:default",
    "process:default",
    "sql:default",
    "store:default",
    "updater:default",
    "window-state:default",
    "global-shortcut:default"
  ]
}
